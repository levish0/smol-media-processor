{
  "name": "smol-media-processor",
  "version": "0.2.0",
  "description": "Small Bun/Elysia service that normalizes uploaded images to WebP and videos to MP4.",
  "author": "Levi Laine <shiueo.csh@gmail.com>",
  "repository": "https://github.com/levish0/smol-media-processor",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "fmt": "bunx prettier --write src/",
    "fmt:check": "bunx prettier --check src/"
  },
  "dependencies": {
    "elysia": "^1.4.29",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.4"
  },
  "module": "src/index.ts"
}
